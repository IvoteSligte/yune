    f: Fn((), Int) = ||: Int = 0
    f()

    s: String = longString#This is a very long,
        multi-line string.
        It contains several newlines.
        Something fancy it supports is quotes "" and even hashtags#!

    println(findChar("this contains ! somewhere", 0, "!"))

