mod(n: Int, m: Int): Int =
    n - ((n / m) * m)

boolToString(value: Bool): String =
    value == true -> "true"
    "false"

intToString(value: Int): String =
    value < 0 -> "-" + intToString(-value)
    value == 0 -> "0"
    value == 1 -> "1"
    value == 2 -> "2"
    value == 3 -> "3"
    value == 4 -> "4"
    value == 5 -> "5"
    value == 6 -> "6"
    value == 7 -> "7"
    value == 8 -> "8"                       
    value == 9 -> "9"
    intToString(value / 10) + intToString(mod(value, 10))

toString(value: Union[Int, Bool, String, ()]): String =
    value is int: Int -> intToString(int)
    value is bool: Bool -> boolToString(bool)
    value is string: String -> string
    "()"

println(value: Union[Int, Bool, String, ()]): () =
    printlnString(toString(value)) // FIXME: things break without parens, presumably because of precedence

N: Int = 12

fibonacci(n: Int): Int =
    n == 0 -> 0
    n == 1 -> 1
    fibonacci(n - 1) + fibonacci(n - 2)

add(a: Int, b: Int): Int = a + b

something(f: Fn((), Int)): Int = f()

takeTuple(t: (Int, String)): String =
    "literal"

longString(text: String, getType: Fn(String, Type)): Union[String, Expression] =
    getType("add") // test getType
    stringLiteral(text)

noArguments(): () = a: Int = 0

findChar(text: String, offset: Int, char: String): Union[Int, ()] =
    offset < len(text) ->
        at(text, offset) == char -> offset
        findChar(text, offset + 1, char)

findBraces(text: String, offset: Int): Union[(Int, Int), ()] =
    findChar(text, offset, "{") is leftIndex: Int ->
        findChar(text, leftIndex + 1, "}") is rightIndex: Int ->
            (leftIndex, rightIndex)
        println("not right")
    println("not left")

stringContains(string: String, char: String): Bool =
    len(string) == 0 -> true
    at(string, 0) == char -> true
    stringContains(subString(string, 1, len(string)), char)

stringContainsOnly(string: String, charSet: String): Bool =
    len(string) == 0 -> true
    ;stringContains(charSet, at(string, 0)) -> false
    stringContainsOnly(subString(string, 1, len(string)), charSet)

LOWER_ALPHA: String = "abcdefghijklmnopqrstuvwxyz"
UPPER_ALPHA: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
ALPHA: String = LOWER_ALPHA + UPPER_ALPHA
DIGIT: String = "1234567890"
ALNUM: String = ALPHA + DIGIT

isAlpha(string: String): Bool = stringContainsOnly(string, ALPHA)
isAlnum(string: String): Bool = stringContainsOnly(string, ALNUM)

isIdentifier(string: String): Bool =
    len(string) == 0 -> false
    ;isAlpha(at(string, 0)) -> false
    isAlnum(subString(string, 1, len(string)))

Error: Type = String

// String interpolation (a.k.a. formatting or f-string) macro.
fmt(text: String, getType: Fn(String, Type)): Union[Expression, Error] =
    // FIXME: why does `func(;x)` error without the parens?

    braces: Union[(Int, Int), ()] = findBraces(text, 0)
    braces is nothing: () ->
        println("EMTPY")
        stringLiteral(text)
    braces is found: (Int, Int)
    (leftIndex: Int, rightIndex: Int) = found
    leftIndex + 1 == rightIndex ->
        println("AYE CAPN")
        println(leftIndex+1)
        println(rightIndex)
        stringLiteral(text)

    braceText: String = subString(text, leftIndex + 1, rightIndex)
    ;isIdentifier(braceText) -> "'" + braceText + "' is not a valid identifier."
    braceTextType: Type = getType(braceText)
    braceTextType ;= String -> "Only strings can be formatted for now."

    remainderResult: Union[Expression, Error] =
        fmt(subString(text, rightIndex + 1, len(text)), getType)
    
    remainderResult is error: Error -> error
    remainderResult is right: Expression
    left: Expression = binaryExpression("+", stringLiteral(subString(text, 0, leftIndex)), variable(braceText))
    test: Expression = right
    binaryExpression("+", left, right)

sql(text: String, getType: Fn(String, Type)): Union[String, Expression] =
    stringLiteral(text)

